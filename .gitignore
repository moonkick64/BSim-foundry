# External dependencies (cloned by bootstrap)
/sighthouse/

# Docker runtime data (BSim postgres)
/data/

# Work tree — entirely scratch/regenerated (extracted .o, ghidra projects,
# logs, configs, the bootstrap-copied analyzer script, staging dumps).
# bootstrap.sh + ingest.py recreate everything here.
/work/

# Generated signatures — distributed via GitHub Releases, not git.
# Regenerate with ./scripts/dump-signatures.sh, package with
# ./scripts/package-signatures.sh.
/signatures/
/signatures*.tar.gz

# Consumer output — Ghidra projects created by scripts/identify.sh.
/bsim-out/

